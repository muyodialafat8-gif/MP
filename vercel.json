{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/(movie|series|watch|search|trending|subscription|account|login|register|watchlist|downloads|notifications|settings|admin|adult)",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
